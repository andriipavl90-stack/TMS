{
  "name": "team-management-server",
  "version": "1.0.0",
  "description": "Team Management System Server",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo 'No build step required for Node.js server'",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "migrate:roles": "node src/scripts/migrate-roles.js",
    "migrate:roles:dry": "node src/scripts/migrate-roles.js --dry-run",
    "migrate:job-profiles": "node src/scripts/migrate-job-profiles.js",
    "migrate:job-profiles:dry": "node src/scripts/migrate-job-profiles.js --dry-run",
    "migrate:interviews": "node src/scripts/migrate-interviews-to-tickets.js",
    "migrate:interviews:dry": "node src/scripts/migrate-interviews-to-tickets.js --dry-run"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4",
    "multer": "^1.4.5-lts.1",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@jest/globals": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

 